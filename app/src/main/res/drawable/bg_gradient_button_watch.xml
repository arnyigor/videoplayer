<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
        android:shape="rectangle">
    <!-- Градиент от красного к оранжевому (стильный акцент) -->
    <gradient
            android:angle="90"
            android:startColor="#D10000"
            android:centerColor="#FF4500"
            android:endColor="#FF7B00"
            android:type="linear" />
    <!-- Закругление в стиле Material 3 -->
    <corners android:radius="12dp" />
</shape>
