<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="560dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="28dp"
        android:paddingEnd="32dp"
        android:paddingBottom="28dp"
        android:background="@android:color/background_dark"
        android:gravity="center_horizontal">

    <TextView
            android:id="@+id/tvUpdateProgressTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/updating_all"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center_horizontal"
            android:paddingBottom="8dp" />

    <TextView
            android:id="@+id/tvUpdateStage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@android:color/darker_gray"
            android:gravity="center_horizontal"
            android:paddingBottom="16dp"
            tools:visibility="visible"
            android:visibility="gone" />

    <ProgressBar
            android:id="@+id/tvUpdateSpinner"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminate="true"
            android:layout_marginTop="4dp" />

    <TextView
            android:id="@+id/tvUpdateProgressPercent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/please_wait"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:gravity="center_horizontal" />

    <Button
            android:id="@+id/tvUpdateCancelButton"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/cancel_update"
            android:focusable="true"
            android:focusableInTouchMode="true" />
</LinearLayout>