<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent" >

    <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsing_toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:contentScrim="@color/colorPrimary"
                app:expandedTitleGravity="bottom"
                app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
                app:scrimAnimationDuration="200"
                app:scrimVisibleHeightTrigger="?attr/actionBarSize"
                app:title=" "
                app:toolbarId="@+id/toolbar"
                app:collapsedTitleTextAppearance="@style/CollapsingToolbarTitle"
                app:expandedTitleTextAppearance="@style/CollapsingToolbarTitleExpanded"
                app:titleEnabled="true">

            <!-- 1. Постер с градиентом - ПЕРВЫЙ, параллакс эффект -->
            <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.7">

                <ImageView
                        android:id="@+id/ivBanner"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        app:layout_constraintDimensionRatio="3:4"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:src="@tools:sample/backgrounds/scenic" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 2. Информация поверх постера - parallax, исчезает при свёртывании -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="?attr/actionBarSize"
                    android:orientation="vertical"
                    android:background="@color/colorOverlay"
                    android:paddingHorizontal="16dp"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.3">

                <!-- Рейтинги -->
                <LinearLayout
                        android:id="@+id/llRatings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <!-- IMDB Badge -->
                    <LinearLayout
                            android:id="@+id/llImdb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rating_imdb"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:visibility="gone"
                            tools:visibility="visible">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="IMDb"
                                android:textColor="#000000"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        <TextView
                                android:id="@+id/tvImdbRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="#000000"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="7.5" />
                    </LinearLayout>

                    <!-- KP Badge -->
                    <LinearLayout
                            android:id="@+id/llKp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_rating_kp"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:visibility="gone"
                            tools:visibility="visible">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="КП"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        <TextView
                                android:id="@+id/tvKpRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                tools:text="6.8" />
                    </LinearLayout>

                    <!-- Лайки -->
                    <TextView
                            android:id="@+id/tvLikes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            tools:text="👍 150  👎 30" />

                    <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                    <!-- Избранное -->
                    <ImageView
                            android:id="@+id/ivFavorite"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_circle_ripple"
                            android:clickable="true"
                            android:contentDescription="@string/favorite"
                            android:focusable="true"
                            android:padding="10dp"
                            app:srcCompat="@drawable/outline_favorite_24"
                            app:tint="@color/colorAccent" />

                </LinearLayout>

                <!-- Название -->
                <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:shadowColor="#000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="4"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="Очень длинное название фильма" />

                <!-- Год, тип, страна -->
                <TextView
                        android:id="@+id/tvTypeYear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#BBBBBB"
                        android:textSize="14sp"
                        tools:text="2023 • Сериал • 3 сезона • США" />

            </LinearLayout>

            <!-- 3. Toolbar - ПОСЛЕДНИЙ, закрепляется при свёртывании -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/colorPrimary"
                app:contentInsetStartWithNavigation="0dp"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:navigationIconTint="@android:color/white"
                app:titleTextColor="@android:color/white"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Основной контент -->
    <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"  >

            <!-- Быстрая информация (чипы) -->
            <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                <LinearLayout
                        android:id="@+id/llQuickInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <!-- Длительность -->
                    <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_info_chip"
                            android:drawablePadding="6dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:visibility="gone"
                            app:drawableStartCompat="@drawable/ic_timer"
                            app:drawableTint="@color/colorAccent"
                            tools:text="1:35:00"
                            tools:visibility="visible" />

                    <!-- Качество -->
                    <TextView
                            android:id="@+id/tvQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_info_chip"
                            android:drawablePadding="6dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:visibility="gone"
                            app:drawableStartCompat="@drawable/ic_hd"
                            app:drawableTint="@color/colorAccent"
                            tools:text="BDRip"
                            tools:visibility="visible" />

                    <!-- Обновлено -->
                    <TextView
                            android:id="@+id/tvUpdated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_info_chip"
                            android:drawablePadding="6dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            app:drawableStartCompat="@drawable/ic_update"
                            app:drawableTint="@color/colorAccent"
                            tools:text="10 фев 2024" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Статус загрузки -->
            <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSaveData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_success_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    tools:visibility="visible">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                    <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_download_done"
                            app:tint="@color/colorAccent" />

                    <TextView
                            android:id="@+id/tvSaveData"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            tools:text="Сохранён: 45.2% • 500 МБ" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Выбор сезона/эпизода для сериалов -->
            <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSeasons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_dark_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    tools:visibility="visible">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                    <TextView
                            android:id="@+id/tvSeasons"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/seasons"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:baselineAligned="false"
                            android:orientation="horizontal">

                        <Spinner
                                android:id="@+id/spinSeasons"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_spinner"
                                android:paddingHorizontal="12dp"
                                tools:listitem="@layout/i_track_select_text" />

                        <Spinner
                                android:id="@+id/spinEpisodes"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_spinner"
                                android:paddingHorizontal="12dp"
                                tools:listitem="@layout/i_track_select_text" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Выбор ссылки для фильмов -->
            <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLinks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_dark_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    tools:visibility="visible">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                    <TextView
                            android:id="@+id/tvLinkTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/link"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    <Spinner
                            android:id="@+id/spinLinks"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_spinner"
                            android:paddingHorizontal="12dp"
                            tools:listitem="@layout/i_track_select_text" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Описание -->
            <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/card_dark_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                    <TextView
                            android:id="@+id/tvDescriptionLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/movie_description"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    <TextView
                            android:id="@+id/tvDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="3dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            tools:text="@tools:sample/lorem/random" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Жанры -->
            <TextView
                    android:id="@+id/tvGenres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/genre"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chgrGenres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp" />

            <!-- Режиссёры -->
            <TextView
                    android:id="@+id/tvDirectors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/directors"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chgrDirectors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp" />

            <!-- Актёры -->
            <TextView
                    android:id="@+id/tvActors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/actors"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chgrActors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Кнопка воспроизведения -->
    <LinearLayout
            android:id="@+id/llBottomButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_button"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/watch"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/colorAccent"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_play_arrow"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="24dp"
                app:iconTint="@color/colorPrimary" />

    </LinearLayout>

    <!-- Прогресс -->
    <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>