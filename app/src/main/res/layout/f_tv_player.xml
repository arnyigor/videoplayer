<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:focusable="true"
        android:focusableInTouchMode="true">

    <com.google.android.exoplayer2.ui.StyledPlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:show_buffering="when_playing" />

    <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#CC000000"
            android:padding="32dp"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:gravity="center"
            android:visibility="gone" />

    <!-- Название фильма/сериала (всегда видимо сверху) -->
    <TextView
            android:id="@+id/tvMovieTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:background="@drawable/gradient_top_dark"
            android:padding="24dp"
            android:paddingTop="32dp"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone" />

    <!-- Информация о текущем эпизоде -->
    <TextView
            android:id="@+id/tvEpisodeInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="100dp"
            android:background="#AA000000"
            android:padding="16dp"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:gravity="center"
            android:visibility="gone" />

    <!-- Панель управления -->
    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/controlsGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom_dark"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:visibility="gone">

        <!-- Кнопка назад -->
        <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/tv_button_selector"
                android:contentDescription="@string/back"
                android:focusable="true"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:padding="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@android:color/white"
                android:nextFocusRight="@id/btnPrevious"
                android:nextFocusDown="@id/btnRewind" />

        <!-- SeekBar -->
        <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:focusable="false"
                android:max="1000"
                android:progressTint="@color/colorAccent"
                android:thumbTint="@color/colorAccent"
                android:progressBackgroundTint="#80FFFFFF"
                app:layout_constraintBottom_toBottomOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="@id/btnBack" />

        <!-- Предыдущий эпизод -->
        <ImageButton
                android:id="@+id/btnPrevious"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/tv_button_selector"
                android:contentDescription="@string/previous_episode"
                android:focusable="true"
                android:src="@drawable/ic_skip_previous"
                android:scaleType="centerInside"
                android:padding="14dp"
                app:layout_constraintEnd_toStartOf="@id/btnRewind"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/seekBar"
                app:tint="@android:color/white"
                android:visibility="gone"
                android:nextFocusRight="@id/btnRewind"
                android:nextFocusLeft="@id/btnBack"
                android:nextFocusUp="@id/btnBack" />

        <!-- Перемотка назад -->
        <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="24dp"
                android:background="@drawable/tv_button_selector"
                android:contentDescription="@string/rewind"
                android:focusable="true"
                android:src="@drawable/ic_fast_rewind"
                android:scaleType="centerInside"
                android:padding="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvCurrentTime"
                app:layout_constraintStart_toEndOf="@id/btnPrevious"
                app:layout_constraintTop_toBottomOf="@id/seekBar"
                app:tint="@android:color/white"
                android:nextFocusRight="@id/btnForward"
                android:nextFocusLeft="@id/btnPrevious"
                android:nextFocusUp="@id/btnBack" />

        <!-- Текущее время -->
        <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:gravity="center"
                android:text="00:00"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/btnRewind"
                app:layout_constraintEnd_toStartOf="@id/tvDuration"
                app:layout_constraintStart_toEndOf="@id/btnRewind"
                app:layout_constraintTop_toTopOf="@id/btnRewind" />

        <!-- Длительность -->
        <TextView
                android:id="@+id/tvDuration"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:gravity="center"
                android:text="00:00"
                android:textColor="#CCFFFFFF"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="@id/btnForward"
                app:layout_constraintEnd_toStartOf="@id/btnForward"
                app:layout_constraintStart_toEndOf="@id/tvCurrentTime"
                app:layout_constraintTop_toTopOf="@id/btnForward" />

        <!-- Перемотка вперёд -->
        <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/tv_button_selector"
                android:contentDescription="@string/forward"
                android:focusable="true"
                android:src="@drawable/ic_fast_forward"
                android:scaleType="centerInside"
                android:padding="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnNext"
                app:layout_constraintStart_toEndOf="@id/tvDuration"
                app:layout_constraintTop_toBottomOf="@id/seekBar"
                app:tint="@android:color/white"
                android:nextFocusLeft="@id/btnRewind"
                android:nextFocusRight="@id/btnNext"
                android:nextFocusUp="@id/btnBack" />

        <!-- Следующий эпизод -->
        <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/tv_button_selector"
                android:contentDescription="@string/next_episode"
                android:focusable="true"
                android:src="@drawable/ic_skip_next"
                android:scaleType="centerInside"
                android:padding="14dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnForward"
                app:layout_constraintTop_toBottomOf="@id/seekBar"
                app:tint="@android:color/white"
                android:visibility="gone"
                android:nextFocusLeft="@id/btnForward"
                android:nextFocusUp="@id/btnBack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>